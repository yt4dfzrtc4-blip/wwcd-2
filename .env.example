# Copie ce fichier en .env.local et remplis les valeurs
# Tu trouveras ces valeurs dans ton dashboard Supabase > Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://TON-PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ta-cle-anon-ici

# Clé service role Supabase (backend uniquement, ne jamais exposer côté client)
SUPABASE_SERVICE_ROLE_KEY=ta-cle-service-role-ici

# Secret pour protéger les routes appelées par Vercel Cron
# Génère une valeur aléatoire : openssl rand -base64 32
CRON_SECRET=un-secret-aleatoire-ici
